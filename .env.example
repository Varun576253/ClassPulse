# Database
# Local PostgreSQL: postgresql://postgres:password@localhost:5432/classpulse
# Free cloud option: create a database at neon.tech and copy the connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname
PG_SSL=true

# AI (Gemini)
# Get a key at aistudio.google.com.
GEMINI_API_KEY=your-gemini-api-key
# Default tested model for this app.
GEMINI_MODEL=gemini-2.5-flash

# WhatsApp (no longer used - replaced by QR code)
# Real WhatsApp delivery and incoming replies (Green API)
# Create an instance at green-api.com, scan the QR code with WhatsApp, then copy these values.
GREENAPI_INSTANCE_ID=your-instance-id
GREENAPI_API_TOKEN=your-api-token
GREENAPI_TIMEOUT_MS=15000
DEBUG_WEBHOOKS=false

# Real SMS password-reset codes (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SMS_FROM=+1234567890
PASSWORD_RESET_TTL_MINUTES=10

# Server
API_PORT=3000
APP_BASE_URL=http://localhost:5000
DEFAULT_COUNTRY_CODE=91
ASSESSMENT_QUEUE_CONCURRENCY=2
ASSESSMENT_QUEUE_MAX_RETRIES=3
# Optional: set this to your ngrok/reverse-proxy URL, for example https://example.ngrok-free.app
PUBLIC_WEBHOOK_URL=
