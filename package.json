{
  "name": "classpulse",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run server\" \"npm run client\"",
    "server": "node node_modules/nodemon/bin/nodemon.js --ignore dist --ignore ShikshaLens --ignore .classpulse-web-port server/index.js",
    "client": "node node_modules/vite/bin/vite.js --config client/vite.config.mjs",
    "seed": "node server/seed.js",
    "replay:webhook": "node server/scripts/replayGreenApiWebhook.js",
    "build": "node node_modules/vite/bin/vite.js build --config client/vite.config.mjs",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.12.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "qrcode": "^1.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.7.2",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.8",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "tailwindcss": "4.1.8",
    "vite": "^6.3.5"
  }
}
